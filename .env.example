# ============================================================================
# Flasky Application Environment Configuration
# ============================================================================
# Copy this file to .env and modify the values as needed for your environment

# ----------------------------------------------------------------------------
# Flask Core Configuration
# ----------------------------------------------------------------------------
FLASK_APP=flasky.py
FLASK_CONFIG=development
FLASK_DEBUG=1
FLASK_ENV=development

# Flask development server settings
# Flask CLI uses FLASK_RUN_HOST / FLASK_RUN_PORT (not FLASK_HOST/FLASK_PORT)
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5060

# Server name for URL generation (optional, format: host:port)
# Leave empty for development, set for production absolute URL generation
SERVER_NAME=

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
# Secret key for session signing, CSRF protection, etc.
# IMPORTANT: Change this to a random string in production!
SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# Development database (MySQL/MariaDB recommended)
# DEV_DATABASE_URL=mysql+pymysql://username:password@localhost:3306/database_name?charset=utf8mb4

# Development database (PostgreSQL alternative)
DEV_DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Production database
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/database_name?charset=utf8mb4

# Production database (PostgreSQL alternative)  
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Test database (usually in-memory SQLite)
TEST_DATABASE_URL=sqlite://

# ----------------------------------------------------------------------------
# Email Configuration (for password reset, notifications, etc.)
# ----------------------------------------------------------------------------
# SMTP server settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Email settings
FLASKY_MAIL_SUBJECT_PREFIX=[Flasky]
FLASKY_MAIL_SENDER=Flasky Admin <noreply@yoursite.com>

# Administrator email (receives error reports in production)
FLASKY_ADMIN=admin@yoursite.com

# ----------------------------------------------------------------------------
# Application Behavior
# ----------------------------------------------------------------------------
# Pagination settings
FLASKY_POSTS_PER_PAGE=20
FLASKY_FOLLOWERS_PER_PAGE=50
FLASKY_COMMENTS_PER_PAGE=30

# Performance monitoring
FLASKY_SLOW_DB_QUERY_TIME=0.5

# ----------------------------------------------------------------------------
# Development/Testing
# ----------------------------------------------------------------------------
# Coverage testing
FLASK_COVERAGE=0

# ----------------------------------------------------------------------------
# Docker/Production Specific
# ----------------------------------------------------------------------------
# For Docker deployments, you may want to override:
# FLASK_CONFIG=production
# FLASK_DEBUG=0
# FLASK_ENV=production

# ----------------------------------------------------------------------------
# Example Values for Different Environments
# ----------------------------------------------------------------------------

# Development (local):
# DEV_DATABASE_URL=mysql+pymysql://polaris:polaris.2025@127.0.0.1:3306/polaris?charset=utf8mb4
# SERVER_NAME=127.0.0.1:5060

# Development (PostgreSQL local):
# DEV_DATABASE_URL=postgresql://polaris:polaris.2025@127.0.0.1:5432/polaris

# Development (network access):
# DEV_DATABASE_URL=mysql+pymysql://polaris:polaris.2025@127.0.0.1:3306/polaris?charset=utf8mb4
# SERVER_NAME=10.127.120.163:5060
# FLASK_RUN_HOST=0.0.0.0

# Production:
# FLASK_CONFIG=production
# FLASK_DEBUG=0
# FLASK_ENV=production
# DATABASE_URL=mysql+pymysql://user:pass@db.example.com:3306/flasky_prod?charset=utf8mb4
# SERVER_NAME=yourdomain.com

# Production (PostgreSQL):
# FLASK_CONFIG=production
# FLASK_DEBUG=0
# FLASK_ENV=production
# DATABASE_URL=postgresql://user:pass@db.example.com:5432/flasky_prod
# SERVER_NAME=yourdomain.com

# Production (PostgreSQL with SSL):
# DATABASE_URL=postgresql://user:pass@db.example.com:5432/flasky_prod?sslmode=require
